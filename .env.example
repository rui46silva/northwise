# ─────────────────────────────────────────────────────────────
# Northwise — environment variables
# Copy this file to `.env.local` and fill in the values.
# ─────────────────────────────────────────────────────────────

# Canonical site URL (used for SEO metadata, sitemap, canonical tags)
NEXT_PUBLIC_SITE_URL=https://northwise.pt

# Google Analytics 4 — Measurement ID (format: G-XXXXXXXXXX)
# Leave empty to disable analytics (e.g. in development).
NEXT_PUBLIC_GA_ID=

# ── Lead form: email delivery via Resend (https://resend.com) ──
# Create an API key in the Resend dashboard.
RESEND_API_KEY=

# Verified sender (must be a domain/address verified in Resend).
CONTACT_FROM_EMAIL=leads@northwise.pt
# Where new lead notifications are delivered.
CONTACT_TO_EMAIL=hello@northwise.pt

# ── CRM: HubSpot (https://hubspot.com) ──
# Private App access token with crm.objects.contacts.write scope.
# Leave empty to skip CRM sync (email still works).
HUBSPOT_ACCESS_TOKEN=
